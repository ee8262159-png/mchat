rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Safety & Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string && data.uid == request.auth.uid &&
               data.displayName is string && data.displayName.size() <= 50 &&
               data.username is string && data.username.size() <= 30 &&
               data.username.matches('^[a-z0-9_]+$');
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'username', 'bio', 'photoURL', 'isOnline', 'lastSeen', 'onboarded', 'updatedAt']);
    }

    // --- Chats ---
    match /chats/{chatId} {
      function isParticipant() {
        return isSignedIn() && (resource == null || request.auth.uid in resource.data.participants);
      }

      function isChatMember(cid) {
        return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(cid)).data.participants;
      }

      function isValidChat(data) {
        return data.type in ['dm', 'group'] &&
               data.participants is list && data.participants.size() >= 2 &&
               request.auth.uid in data.participants;
      }

      allow get: if isParticipant();
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isParticipant() && 
                    (incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']) ||
                     (existing().type == 'group' && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'participants'])));

      // --- Typing ---
      match /typing/{userId} {
        allow read: if isChatMember(chatId);
        allow write: if isOwner(userId) && isChatMember(chatId);
      }

      // --- Messages ---
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.senderId == request.auth.uid &&
                 (data.timestamp == request.time || data.timestamp == null || data.timestamp is timestamp);
        }

        allow read, list: if isChatMember(chatId);
        allow create: if isChatMember(chatId) && isValidMessage(incoming());
        allow update: if isChatMember(chatId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['readBy', 'reactions']) ||
          (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['mediaUrl', 'text', 'status', 'timestamp']))
        );
        allow delete: if isChatMember(chatId) && existing().senderId == request.auth.uid;
      }
    }

  }
}
